{
  "name": "claude-session-deck",
  "displayName": "Session Deck for Claude Code",
  "description": "Card-based session manager for Claude Code in VS Code — align, reorder, color-code your conversations",
  "version": "0.1.3",
  "publisher": "ethanHomePc",
  "repository": {
    "type": "git",
    "url": "https://github.com/ethanHomePc/claude-session-deck"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-session-manager.open",
        "title": "Session Deck: Open Claude Session Manager"
      }
    ],
    "keybindings": [
      {
        "command": "claude-session-manager.open",
        "key": "ctrl+shift+alt+c"
      }
    ]
  }
}
